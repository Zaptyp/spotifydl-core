{
  "name": "@zaptyp/spotifydl-core",
  "version": "0.4.1",
  "description": "Spotify downloader for node",
  "main": "dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "types": "dist",
  "type": "module",
  "scripts": {
    "build": "tsc -p .",
    "test": "node tests",
    "docs": "typedoc",
    "prepare": "npm run build",
    "prettier-format": "prettier --config .prettierrc \"src/**/*.ts\" --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zaptyp/spotifydl-core.git"
  },
  "keywords": [
    "spotify",
    "spotify-downloader",
    "music"
  ],
  "author": "Alen Yohannan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Zaptyp/spotifydl-core/issues"
  },
  "homepage": "https://github.com/Zaptyp/spotifydl-core#readme",
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.3",
    "@types/yt-search": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.1",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@zaptyp/spotify-web-api-node": "^5.1.3",
    "axios": "^1.13.5",
    "colors": "^1.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.3.3",
    "yt-dlp-core": "^2.4.0",
    "yt-search": "^2.13.1",
    "ytmusic-api": "^5.3.0"
  },
  "overrides": {
    "tough-cookie": {
      "psl": "https://github.com/lupomontero/psl"
    },
    "yt-search": {
      "jsonpath-plus": "^10.3.0"
    }
  }
}
